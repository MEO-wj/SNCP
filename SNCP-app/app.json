{
  "expo": {
    "name": "柠芯食伴",
    "slug": "sncp",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_iron2.png",
    "scheme": "sncpfoodmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "top.handywote.sncpfoodmate",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7EE",
        "foregroundImage": "./assets/images/app_iron2.png"
      },
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "top.handywote.sncpfoodmate"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app_iron2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enablePngCrunchInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许食伴访问照片，用于识别食物并生成营养记录。",
          "cameraPermission": "允许食伴使用相机，用于拍照识别食物并生成营养记录。",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_iron2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF7EE",
          "dark": {
            "backgroundColor": "#171614"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee5d24ec-f97f-4549-94aa-cebf04dea69a"
      }
    },
    "owner": "meowj"
  }
}
