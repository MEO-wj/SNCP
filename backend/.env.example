# Backend service configuration
# If used with docker-compose.yml in this repo, keep host as db.
DATABASE_URL=postgresql://sncp:change-me-db-password@db:5432/sncp
# Startup retry for fresh deploys / cold database boots
# DB_INIT_MAX_ATTEMPTS=30
# DB_INIT_RETRY_DELAY_SECONDS=2

# Auth & JWT
AUTH_JWT_SECRET=change-me
AUTH_REFRESH_HASH_KEY=change-me-too
# seconds (defaults: 3600 / 604800)
# AUTH_ACCESS_TOKEN_TTL=604800
# AUTH_REFRESH_TOKEN_TTL=604800
# AUTH_PASSWORD_COST=12
# ADMIN_PHONES=13800138000,13900139000

# Redis (optional)
# If used with docker-compose.yml in this repo, keep host as redis.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# Docker image overrides do not belong in this file.
# If you need a registry mirror for docker compose, copy
# docker-compose.mirror.example.yml to docker-compose.override.yml
# and edit the image names there.

# CORS
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your.domain

# Rate limit (optional; unset to disable)
# RATE_LIMIT_PER_DAY=1000
# RATE_LIMIT_PER_HOUR=100

# AI (food recognition / nutrition analysis / recipe recommend)
# AI_FOOD_RECOGNITION_URL=https://your.ai/food/recognize
# AI_FOOD_RECOGNITION_KEY=your_key
# AI_NUTRITION_ANALYSIS_URL=https://your.ai/nutrition/analyze
# AI_NUTRITION_ANALYSIS_KEY=your_key
# AI_RECIPE_RECOMMEND_URL=https://your.ai/recipe/recommend
# AI_RECIPE_RECOMMEND_KEY=your_key
#
# Direct Zhipu AI integration
# ZHIPU_API_KEY=your_zhipu_api_key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_VISION_MODEL=glm-4.6v
# ZHIPU_TEXT_MODEL=glm-4.7
#
# External recipe source: TheMealDB official API.
# The default development key is "1". For commercial/public distribution,
# review TheMealDB licensing and switch to your own subscriber key if needed.
# THEMEALDB_BASE_URL=https://www.themealdb.com/api
# THEMEALDB_API_KEY=1
# Admin bootstrap (optional)
# ADMIN_LOGIN_NAME=admin
# ADMIN_PHONE=13800138000
# ADMIN_PASSWORD=change-me
# ADMIN_DISPLAY_NAME=admin
