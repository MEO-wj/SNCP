# Backend service configuration
# If used with docker-compose.yml in this repo, keep host as db.
DATABASE_URL=postgresql://sncp:change-me-db-password@db:5432/sncp
POSTGRES_DB=sncp
POSTGRES_USER=sncp
POSTGRES_PASSWORD=change-me-db-password
# Startup retry for fresh deploys / cold database boots
# DB_INIT_MAX_ATTEMPTS=30
# DB_INIT_RETRY_DELAY_SECONDS=2

# Auth & JWT
AUTH_JWT_SECRET=change-me
AUTH_REFRESH_HASH_KEY=change-me-too
# seconds (defaults: 3600 / 604800)
# AUTH_ACCESS_TOKEN_TTL=604800
# AUTH_REFRESH_TOKEN_TTL=604800
# AUTH_PASSWORD_COST=12
# ADMIN_PHONES=13800138000,13900139000

# Redis (optional)
# If used with docker-compose.yml in this repo, keep host as redis.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# Docker image overrides do not belong in this file.
# If you need a registry mirror for docker compose, copy
# docker-compose.mirror.example.yml to docker-compose.override.yml
# and edit the image names there.

# CORS
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your.domain

# Rate limit (optional; unset to disable)
# RATE_LIMIT_PER_DAY=1000
# RATE_LIMIT_PER_HOUR=100

# AI (food recognition / nutrition analysis / recipe recommend)
# AI_FOOD_RECOGNITION_URL=https://your.ai/food/recognize
# AI_FOOD_RECOGNITION_KEY=your_key
# AI_NUTRITION_ANALYSIS_URL=https://your.ai/nutrition/analyze
# AI_NUTRITION_ANALYSIS_KEY=your_key
# AI_RECIPE_RECOMMEND_URL=https://your.ai/recipe/recommend
# AI_RECIPE_RECOMMEND_KEY=your_key
#
# Direct Zhipu AI integration
# ZHIPU_API_KEY=your_zhipu_api_key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_VISION_MODEL=glm-4.6v
# ZHIPU_TEXT_MODEL=glm-4.7
#
# YOLO food detector as the second vision judge. The Dockerfile installs
# the optional yolo dependency group; keep these paths relative to /app.
# YOLO_FOOD_ENABLED=true
# YOLO_FOOD_WEIGHT_PATH=ai_end/models/yolo_food/cafeteria_yolo_uec.pt
# YOLO_FOOD_LABELS_PATH=ai_end/models/yolo_food/label_names_zh.json
# YOLO_FOOD_ALIASES_PATH=ai_end/models/yolo_food/yolo_to_catalog_aliases.json
# YOLO_FOOD_DEVICE=auto
# YOLO_FOOD_CONF=0.55
# YOLO_FOOD_REQUIRE_REFERENCE=false
#
# External recipe source: TheMealDB official API.
# The default development key is "1". For commercial/public distribution,
# review TheMealDB licensing and switch to your own subscriber key if needed.
# THEMEALDB_BASE_URL=https://www.themealdb.com/api
# THEMEALDB_API_KEY=1
# App update (Android APK distribution)
# These values act as fallback defaults when the admin backend has not saved
# a database release configuration yet. Once the admin page saves settings,
# GET /api/update/check will prefer the database values.
# Publish metadata used by GET /api/update/check
# APP_UPDATE_LATEST_VERSION=1.4.0
# APP_UPDATE_LATEST_BUILD=42
# APP_UPDATE_MIN_SUPPORTED_BUILD=40
# APP_UPDATE_FORCE_UPDATE=false
# APP_UPDATE_PUBLISHED_AT=2026-04-29T09:30:00+08:00
# APP_UPDATE_RELEASE_NOTES=优化推荐页体验|修复活跃时间统计|支持版本检测
#
# Option A: let this backend host the APK file directly
# The default fixed release directory is /app/releases. In docker-compose,
# it is mapped from ../releases on the host machine.
# APP_UPDATE_ANDROID_RELEASE_DIR=/app/releases
# Upload the APK into the host releases directory, then only set its file name.
# APP_UPDATE_ANDROID_DOWNLOAD_NAME=sncp-v1.4.0.apk
# APP_UPDATE_ANDROID_APK_PATH=backend/releases/sncp-v1.4.0.apk
#
# Option B: redirect users to an external HTTPS download URL
# APP_UPDATE_ANDROID_APK_URL=https://download.your.domain/sncp/sncp-v1.4.0.apk
#
# Optional iOS store/TestFlight link for future use
# APP_UPDATE_IOS_URL=https://apps.apple.com/app/idxxxxxxxxxx
# Admin bootstrap (optional)
# ADMIN_LOGIN_NAME=admin
# ADMIN_PHONE=13800138000
# ADMIN_PASSWORD=change-me
# ADMIN_DISPLAY_NAME=admin
